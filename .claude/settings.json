{
  "permissions": {
    "allow": [
      "Read(src/**)",
      "Read(tests/**)",
      "Read(environment_features.json)",
      "Read(features.json)",
      "Read(claude-progress.txt)",
      "Read(CLAUDE.md)",
      "Edit(src/**)",
      "Edit(tests/**)",
      "Edit(environment_features.json)",
      "Edit(features.json)",
      "Edit(claude-progress.txt)",
      "Bash(python:*)",
      "Bash(pip:*)",
      "Bash(pytest:*)",
      "Bash(curl:*)",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(node:*)",
      "Bash(cat:*)",
      "Bash(ls:*)",
      "Bash(cd:*)",
      "Bash(git:*)"
    ],
    "deny": [
      "Read(.env*)",
      "Read(**/*.pem)",
      "Read(**/secrets/**)",
      "Bash(rm -rf:*)",
      "Bash(git push --force:*)"
    ]
  },
  "env": {
    "PYTHONPATH": "./src",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "echo '=== Session Protocol ===' && cat features.json | python3 -c 'import sys,json; d=json.load(sys.stdin); p=sum(1 for f in d.get(\"features\",[]) if f.get(\"status\")==\"pending\"); c=sum(1 for f in d.get(\"features\",[]) if f.get(\"status\")==\"completed\"); print(f\"Features: {c} completed, {p} pending\")' 2>/dev/null || echo 'No features.json found'",
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/compliance-log.sh",
            "timeout": 5,
            "pass_message": true
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/issue-detector.sh",
            "timeout": 30,
            "pass_message": true
          }
        ]
      }
    ]
  }
}
{
  "version": "1.0.0",
  "services": {
    "fixture": {
      "source": "build_new",
      "features": ["project-management", "task-management", "dashboard", "navigation"],
      "depends_on": [],
      "constraints": {
        "auth": "GCP Identity Platform",
        "database": "SQLite",
        "orm": "sqlalchemy",
        "backend": "fastapi",
        "frontend": "nextjs"
      },
      "entities": {
        "users": {
          "table": "users",
          "fields": {
            "id": { "type": "uuid", "pk": true },
            "email": { "type": "string", "required": true, "unique": true, "max_length": 255 },
            "hashed_password": { "type": "string", "required": true },
            "name": { "type": "string", "required": true, "max_length": 255 },
            "created_at": { "type": "datetime", "default": "now" }
          },
          "endpoints": {
            "register": { "method": "POST", "path": "/api/auth/register" },
            "login":    { "method": "POST", "path": "/api/auth/login" },
            "me":       { "method": "GET",  "path": "/api/users/me" }
          },
          "ui": {
            "page": "/login",
            "display_name": "Authentication",
            "crud": ["create"]
          }
        },
        "projects": {
          "table": "projects",
          "fields": {
            "id": { "type": "uuid", "pk": true },
            "name": { "type": "string", "required": true, "max_length": 255 },
            "description": { "type": "text" },
            "owner_id": { "type": "uuid", "required": true, "fk": "users.id" },
            "created_at": { "type": "datetime", "default": "now" }
          },
          "endpoints": {
            "create": { "method": "POST",   "path": "/api/projects" },
            "list":   { "method": "GET",    "path": "/api/projects" },
            "read":   { "method": "GET",    "path": "/api/projects/{id}" },
            "delete": { "method": "DELETE", "path": "/api/projects/{id}" }
          },
          "ui": {
            "page": "/projects",
            "display_name": "Projects",
            "crud": ["list", "create", "read", "delete"]
          }
        },
        "tasks": {
          "table": "tasks",
          "fields": {
            "id": { "type": "uuid", "pk": true },
            "title": { "type": "string", "required": true, "max_length": 255 },
            "description": { "type": "text" },
            "project_id": { "type": "uuid", "required": true, "fk": "projects.id" },
            "assignee_id": { "type": "uuid", "fk": "users.id" },
            "status": {
              "type": "string",
              "required": true,
              "default": "pending",
              "enum": ["pending", "in_progress", "done"]
            },
            "created_at": { "type": "datetime", "default": "now" }
          },
          "endpoints": {
            "create": { "method": "POST",   "path": "/api/tasks" },
            "list":   { "method": "GET",    "path": "/api/tasks" },
            "delete": { "method": "DELETE", "path": "/api/tasks/{id}" }
          },
          "ui": {
            "page": "/tasks",
            "display_name": "Tasks",
            "crud": ["list", "create", "delete"]
          }
        }
      },
      "relationships": [
        { "from": "projects", "to": "users",    "field": "owner_id",    "cardinality": "many_to_one" },
        { "from": "tasks",    "to": "projects", "field": "project_id",  "cardinality": "many_to_one" },
        { "from": "tasks",    "to": "users",    "field": "assignee_id", "cardinality": "many_to_one" }
      ],
      "pages": {
        "dashboard": {
          "type": "view_only",
          "path": "/dashboard",
          "display_name": "Dashboard",
          "displays": [
            "total project count for current user",
            "total task count for current user",
            "quick links to /projects and /tasks"
          ]
        },
        "login": {
          "type": "view_only",
          "path": "/login",
          "display_name": "Login",
          "displays": ["login form with email and password"]
        },
        "register": {
          "type": "view_only",
          "path": "/register",
          "display_name": "Register",
          "displays": ["registration form with email, password, and name"]
        },
        "navigation": {
          "type": "view_only",
          "path": "/",
          "display_name": "Navigation and Layout",
          "displays": [
            "sidebar with route highlighting (Dashboard, Projects, Tasks)",
            "logout button clears auth token and redirects to /login",
            "AuthGuard component redirects unauthenticated users to /login",
            "Layout component wraps all authenticated pages"
          ]
        }
      }
    },
    "browser-agent": {
      "source": "existing",
      "url": "https://browser.dreamteamlabs.co.uk",
      "description": "Headless Chrome agent — navigates URLs, takes screenshots, runs smoke tests. Puppeteer-based, deployed on VPS.",
      "health": "GET /health",
      "api": {
        "diagnose": {
          "method": "POST",
          "path": "/diagnose",
          "description": "Navigate to URL, take screenshot, return screenshot URL. No Claude call ($0).",
          "request": { "url": "string (required)" },
          "response": { "success": "boolean", "finalUrl": "string", "screenshotUrl": "string", "events": "array", "elapsed": "number" }
        },
        "explore": {
          "method": "POST",
          "path": "/explore",
          "description": "Full Claude-powered site exploration with feature discovery (~$12).",
          "request": { "url": "string (required)", "maxIterations": "number (default 20)", "timeout": "number" },
          "response": { "success": "boolean", "url": "string", "iterations": "number", "features": "string", "parsed_features": "array" }
        },
        "quick-analyze": {
          "method": "POST",
          "path": "/quick-analyze",
          "description": "Lighter exploration — 10 iterations, 60s timeout (~$5).",
          "request": { "url": "string (required)" },
          "response": { "success": "boolean", "url": "string", "iterations": "number", "parsed_features": "array" }
        },
        "smoke-test": {
          "method": "POST",
          "path": "/smoke-test",
          "description": "QA smoke test with login, CRUD testing, screenshots. Supports mock mode (~$12, mock=$0).",
          "request": { "url": "string (required)", "credentials": "object {email, password}", "features": "array", "maxIterations": "number", "mock": "boolean" },
          "response": "NDJSON stream — progress events then final result line"
        }
      }
    }
  }
}
